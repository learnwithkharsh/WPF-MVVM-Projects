<UserControl x:Class="WpfApp.Views.EmployeeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp.Views"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <DockPanel Margin="10">

            <Button ToolTip="Add User"
                    Style="{StaticResource MahApps.Styles.Button.Flat}" Background="Transparent"
                    DockPanel.Dock="Right"
                    Content="&#xE8FA;"  FontFamily="Segoe MDL2 Assets"
                    Command="{Binding OpenAddDialogCommand}"/>

            <!-- SEARCH -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">

                <ComboBox Width="120"
                      ItemsSource="{Binding ColumnNames}"
                      SelectedItem="{Binding SelectedColumn}"
                      Margin="5"/>

                <TextBox Width="150"
                     Text="{Binding SearchText,UpdateSourceTrigger=PropertyChanged}"
                     Margin="5"/>
                <TextBlock Text="Database: " VerticalAlignment="Center" Margin="5"/>
                <ComboBox Width="120"
                          ItemsSource="{Binding Databases}"
                          SelectedItem="{Binding SelectedDatabase}"
                          Margin="5"/>    

            </StackPanel>

        </DockPanel>

        <!-- DATAGRID -->
        <DataGrid Grid.Row="1"
              ItemsSource="{Binding EmployeesView}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              Margin="10">

            <DataGrid.Columns>

                <DataGridTextColumn Header="#" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                <DataGridTextColumn Header="Gender" Binding="{Binding Gender}"/>
                <DataGridTextColumn Header="Company" Binding="{Binding Company}"/>
                <DataGridTextColumn Header="Roles" Binding="{Binding Role}"/>
                <DataGridTextColumn Header="Country" Binding="{Binding Country}"/>
                <DataGridTextColumn Header="Experience" Binding="{Binding Experience}"/>

                <!-- ACTIONS -->
                <DataGridTemplateColumn Header="Actions" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">

                                <Button Content="Edit"
                                    Margin="5"
                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>

                                <Button Content="Delete"
                                    Margin="5"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- PAGINATION -->
        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="10">

            <Button Style="{StaticResource MahApps.Styles.Button.Flat}" Background="Transparent"
                    Content="&lt;" ToolTip="First" Command="{Binding FirstPageCommand}" />
            <Button Style="{StaticResource MahApps.Styles.Button.Flat}" Background="Transparent"
                    Content="&lt;&lt;" ToolTip="Previous" Command="{Binding PrevPageCommand}" />
            <TextBlock Text="{Binding PageInfo}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Style="{StaticResource MahApps.Styles.Button.Flat}" Background="Transparent"
                    Content="&gt;&gt;" ToolTip="Next" Command="{Binding NextPageCommand}" />
            <Button Style="{StaticResource MahApps.Styles.Button.Flat}" Background="Transparent"
                    Content="&gt;" ToolTip="Last" Command="{Binding LastPageCommand}"/>

            <ComboBox Width="80"
                  ItemsSource="{Binding PageSizes}"
                  SelectedItem="{Binding SelectedPageSize}"
                  Margin="10"/>

        </StackPanel>

    </Grid>
</UserControl>
