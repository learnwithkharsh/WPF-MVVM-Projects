<UserControl x:Class="WpfApp.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp.Views"
             xmlns:converters="clr-namespace:WpfApp.Converters"
             xmlns:ap="clr-namespace:WpfApp.AttachedProperty"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid  RowDefinitions="*,auto">
        <Grid.Resources>
            <converters:MessageColorConverter x:Key="MessageColorConverter"/>
            <converters:AlignmentConverter x:Key="AlignmentConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <Style x:Key="buttonStyle" TargetType="Button">
                <Style.Setters>
                    <Setter Property="Width" Value="36"/>
                    <Setter Property="Height" Value="36"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style.Setters>
            </Style>
        </Grid.Resources>
        <!-- Chat Messages -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      ap:ScrollExtensions.AutoScroll="True">
            <ItemsControl ItemsSource="{Binding Messages}"> 
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10"
                                Padding="10"
                                CornerRadius="12"
                                Background="{Binding IsUser, Converter={StaticResource MessageColorConverter}}">

                            <Grid ColumnDefinitions="*,auto">
                                <!-- Message -->
                                <!--<TextBlock Text="{Binding Content}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,30,0"
                                           HorizontalAlignment="{Binding IsUser, Converter={StaticResource AlignmentConverter}}"/>-->

                                
                                <md:MarkdownScrollViewer 
                                    xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
                                    Markdown="{Binding Content}">
                                    <md:MarkdownScrollViewer.MarkdownStyle>
                                        <Style TargetType="FlowDocument">
                                            <Style.Resources>
                                                <Style TargetType="Paragraph">
                                                    <Setter Property="TextAlignment" Value="Left" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=md:MarkdownScrollViewer}, Path=DataContext.IsUser}" Value="True">
                                                            <Setter Property="TextAlignment" Value="Right" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Style.Resources>
                                        </Style>
                                    </md:MarkdownScrollViewer.MarkdownStyle>
                                </md:MarkdownScrollViewer>
                                <!-- Action Icons -->
                                <StackPanel Orientation="Horizontal"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Opacity="0"
                                            x:Name="ActionPanel">

                                    <!-- Copy Icon -->
                                    <Button Style="{StaticResource MahApps.Styles.Button.Flat}" Background="Transparent"
                                            BorderThickness="0"
                                            ToolTip="Copy"
                                            Content="&#xE8C8;"  FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding DataContext.CopyCommand, 
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Content}"/>

                                </StackPanel>
                            </Grid>

                            <!-- Hover Effect -->
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ActionPanel"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ActionPanel"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input Box -->
        <Grid Grid.Row="1" Margin="10">
            <Border Background="#2D2D30"
                    CornerRadius="20"
                    Padding="8" >

                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                              ShadowDepth="0"
                              Opacity="0.3"/>
                </Border.Effect>

                <Grid ColumnDefinitions="*,auto">
                    <!-- Input Text -->
                    <TextBox Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
							 Background="Transparent" Foreground="White"
                             BorderThickness="0" FontSize="14"
                             VerticalContentAlignment="Center" Padding="10"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MaxHeight="100"/>

                    <!-- Send Button (Arrow Icon) -->
                    <Button Grid.Column="1" Visibility="{Binding IsSendVisible,Converter={StaticResource BooleanToVisibilityConverter}}"
                            Command="{Binding SendCommand}"
                            Style="{StaticResource buttonStyle}"  
                            Content="&#xE724;">
                    </Button>
                    <!-- Stop Button (Stop Icon) -->
                    <Button Grid.Column="1" Visibility="{Binding IsSendVisible,Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource buttonStyle}"                             
                            Content="&#xE71A;">  
                    </Button>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
