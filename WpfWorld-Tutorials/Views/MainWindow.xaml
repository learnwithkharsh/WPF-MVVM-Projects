<mah:MetroWindow x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:beh="clr-namespace:MahApps.Metro.Behaviors;assembly=MahApps.Metro"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:view="clr-namespace:WpfApp.Views"
        xmlns:viewModel="clr-namespace:WpfApp.ViewModels"
        Title="MainWindow" >
    <mah:MetroWindow.DataContext>
        <viewModel:MainWindowViewModel/>
    </mah:MetroWindow.DataContext>
    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands >
            <ComboBox SelectedIndex="0" Background="Transparent" Foreground="White">
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
            </ComboBox>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>
    <mah:MetroWindow.Resources>
        <local:GenderToBoolConverter x:Key="GenderToBoolConverter"/>
        <DataTemplate DataType="{x:Type viewModel:DashboardViewModel}">
            <view:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:EmployeeViewModel}">
            <view:EmployeeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModel:ChatViewModel}">
            <view:ChatView/>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <!-- SIDEBAR -->
    <mah:HamburgerMenu x:Name="MainHamburgerMenu"
                           DisplayMode="CompactInline"
                           mah:PaneBackground="#1E1E2F"
                           SelectedIndex="0">
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="ItemInvoked">
                <i:InvokeCommandAction Command="{Binding ShowViewCommand}"
                            CommandParameter="{Binding ElementName=MainHamburgerMenu,
                             Path=SelectedItem.Tag}"/>
            </i:EventTrigger>
        </i:Interaction.Triggers>

        <mah:HamburgerMenu.ItemTemplate>
            <DataTemplate DataType="{x:Type mah:HamburgerMenuGlyphItem}">
                <DockPanel  LastChildFill="True">
                    <Grid x:Name="IconPart" Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type mah:HamburgerMenu}}, Path=CompactPaneLength}" DockPanel.Dock="Left">
                        <TextBlock Margin="12" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Text="{Binding Glyph}" />
                    </Grid>
                    <TextBlock x:Name="TextPart" VerticalAlignment="Center" FontSize="16" Text="{Binding Label}" />
                </DockPanel>

                <!--<DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type mah:HamburgerMenu}}, Path=PanePlacement}" Value="Right">
                        <Setter TargetName="IconPart" Property="DockPanel.Dock" Value="Left" />
                        <Setter TargetName="TextPart" Property="Margin" Value="8 0 0 0" />
                    </DataTrigger>
                </DataTemplate.Triggers>-->
            </DataTemplate>

        </mah:HamburgerMenu.ItemTemplate>

        <mah:HamburgerMenu.ItemsSource>
            <mah:HamburgerMenuItemCollection>
                <mah:HamburgerMenuGlyphItem Label="Dashboard" Glyph="&#xE9D2;" Tag="Dashboard"/>
                <mah:HamburgerMenuGlyphItem Label="Employee" Glyph="&#xE77B;" Tag="Employee"/>
                <mah:HamburgerMenuGlyphItem Label="Ollama" Glyph="&#xE8BD;" Tag="ChatView"/>
            </mah:HamburgerMenuItemCollection>
        </mah:HamburgerMenu.ItemsSource>

        <mah:HamburgerMenu.Content>
            <!-- MAIN CONTENT -->
            <ContentControl Content="{Binding CurrentView}" />
        </mah:HamburgerMenu.Content>

    </mah:HamburgerMenu>

</mah:MetroWindow>
