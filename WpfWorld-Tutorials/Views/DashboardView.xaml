<UserControl x:Class="WpfApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp.Views"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" >
    <ScrollViewer>
        <UniformGrid Columns="2" Margin="10" >
            <GroupBox Header="Gender Distribution" Margin="10">
                <lvc:PieChart Series="{Binding GenderSeries}" 
                              Margin="10"/>
            </GroupBox>
            <GroupBox Header="Country Distribution" Margin="10">
                <lvc:PieChart Series="{Binding CountrySeries}" 
                                    Margin="10"/>

            </GroupBox>
            <GroupBox Header="Experience Level" Margin="10">
                <lvc:PieChart Series="{Binding ExperienceSeries}" 
                                    Margin="10" />

            </GroupBox>
            <GroupBox Header="Company Overview" Margin="10">
                <lvc:PieChart Series="{Binding CompanySeries}" 
                              Margin="10" />
            </GroupBox>
        </UniformGrid>
    </ScrollViewer>
</UserControl>
